# ===== Application =====
APP_NAME="Bizplay Expense AI Service"
ENVIRONMENT=local
DEBUG=true
API_PREFIX=/api

# ===== Relational Database =====
# 우선순위: DATABASE_URL > DB_URL. SQLAlchemy 가 URI 스킴으로 드라이버를 자동 선택한다.
# 로컬 개발 (SQLite):
DB_URL=sqlite:///./expense_ai.db
# 운영 (PostgreSQL) — 설정 시 DB_URL 보다 우선 적용 (psycopg2 드라이버 자동 선택):
# DATABASE_URL=postgresql+psycopg2://expense_user:CHANGE_ME@db-host:5432/expense_ai

# ===== Vector Database (Qdrant) =====
# 원격 서버 모드(운영/Docker):        QDRANT_URL=http://localhost:6333  (Docker compose 에선 http://qdrant:6333)
# 임베디드 local 모드(설치·서버 불필요): QDRANT_URL=path:./qdrant_local  (로컬 폴더 영속) 또는 :memory: (휘발성)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ===== LLM / Embeddings =====
OPENAI_API_KEY=
# 사내 GPU(RunPod) OpenAI 호환 프록시. 공식 OpenAI 직결 시에는 비워두면 기본값 사용.
OPENAI_API_BASE=https://api.runpod.ai/v2/v7fykeg2rhwgse/openai/v1
# RunPod(vLLM) 프록시 사용 시 해당 엔드포인트가 서빙하는 모델명과 일치해야 한다.
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
# 임베딩 공급자: openai(기본) | fastembed(로컬 ONNX, API 불필요).
# RunPod 처럼 임베딩 라우트가 없으면 fastembed 권장.
EMBEDDING_PROVIDER=openai
# openai:   text-embedding-3-small
# fastembed: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (한국어 지원, 384d)
EMBEDDING_MODEL=text-embedding-3-small

# ===== CORS (comma-separated origins, "*" = all) =====
CORS_ORIGINS=*

# ===== TLS / 사내 CA (corporate proxy SSL inspection 대응) =====
# 회사 네트워크의 SSL 인터셉션 환경에서 외부 LLM/Vector DB 호출이
# self-signed CA 때문에 막힐 때 사용. httpx/openai/urllib3 가 직접 읽는다.
# (.env -> os.environ 전파는 app/core/config.py 의 load_dotenv() 가 담당)
# SSL_CERT_FILE=C:/Bizplay/AI_PROJECT/GeninetworksRootCA.pem
# REQUESTS_CA_BUNDLE=C:/Bizplay/AI_PROJECT/GeninetworksRootCA.pem
