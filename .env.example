# ===== Application =====
APP_NAME="Bizplay Expense AI Service"
ENVIRONMENT=local
DEBUG=true
API_PREFIX=/api

# ===== Relational Database (PostgreSQL) =====
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/expense_ai

# ===== Vector Database (Qdrant) =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ===== LLM / Embeddings =====
OPENAI_API_KEY=
# 사내 GPU(RunPod) OpenAI 호환 프록시. 공식 OpenAI 직결 시에는 비워두면 기본값 사용.
OPENAI_API_BASE=https://api.runpod.ai/v2/v7fykeg2rhwgse/openai/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ===== CORS (comma-separated origins, "*" = all) =====
CORS_ORIGINS=*

# ===== TLS / 사내 CA (corporate proxy SSL inspection 대응) =====
# 회사 네트워크의 SSL 인터셉션 환경에서 외부 LLM/Vector DB 호출이
# self-signed CA 때문에 막힐 때 사용. httpx/openai/urllib3 가 직접 읽는다.
# (.env -> os.environ 전파는 app/core/config.py 의 load_dotenv() 가 담당)
# SSL_CERT_FILE=C:/Bizplay/AI_PROJECT/GeninetworksRootCA.pem
# REQUESTS_CA_BUNDLE=C:/Bizplay/AI_PROJECT/GeninetworksRootCA.pem
